# *********************************************************************
# БАЗОВЫЙ ОБРАЗ
# *********************************************************************
# Используем официальный образ Nginx на основе Alpine Linux.
# Alpine - это минималистичный дистрибутив Linux (всего ~5 МБ).
# Почему Alpine? 
# 1. Очень маленький размер (конечный образ будет ~30-50 МБ вместо 500 МБ)
# 2. Безопаснее (меньше компонентов = меньше уязвимостей)
# 3. Быстрая загрузка и запуск
# *********************************************************************
FROM nginx:alpine

# *********************************************************************
# УСТАНОВКА ДОПОЛНИТЕЛЬНЫХ ПРОГРАММ
# *********************************************************************
# apk - пакетный менеджер Alpine Linux (аналог apt в Ubuntu)
# add - команда установки
# --no-cache - не сохранять кэш пакетов (чтобы образ был меньше)
# *********************************************************************
RUN apk add --no-cache \
    curl \          # Утилита для проверки доступности сайтов/ботов
    vim \           # Текстовый редактор (на случай отладки внутри контейнера)
    certbot \       # Клиент Let's Encrypt для получения SSL сертификатов
    certbot-nginx \ # Плагин certbot для автоматической настройки Nginx
    openssl         # Инструменты для работы с сертификатами (проверка, генерация)

# *********************************************************************
# ОЧИСТКА ДЕФОЛТНЫХ КОНФИГОВ
# *********************************************************************
# Стандартный образ Nginx поставляется с демонстрационными конфигами.
# Они нам не нужны и могут мешать, поэтому удаляем их.
# && - означает "выполнить следующую команду только если предыдущая успешна"
# rm -rf - принудительное удаление (без подтверждения, рекурсивно)
# *********************************************************************
RUN rm -rf /etc/nginx/conf.d/* \           # Удаляем все в папке conf.d
    && rm -rf /etc/nginx/sites-available/* \ # Удаляем примеры сайтов (если есть)
    && rm -rf /etc/nginx/sites-enabled/*     # Удаляем включенные сайты

# *********************************************************************
# СОЗДАНИЕ НЕОБХОДИМЫХ ПАПОК
# *********************************************************************
# Хотя эти папки могут быть созданы позже или примонтированы,
# создаем их заранее для явности и чтобы избежать ошибок прав доступа
# *********************************************************************
RUN mkdir -p /var/www/certbot \          # Папка для файлов подтверждения Let's Encrypt
    && mkdir -p /var/log/nginx \          # Папка для логов (хотя Nginx создаст сам)
    && mkdir -p /etc/nginx/sites-available \ # Папка для доступных конфигов сайтов
    && mkdir -p /etc/nginx/sites-enabled     # Папка для включенных сайтов

# *********************************************************************
# КОПИРОВАНИЕ КОНФИГУРАЦИЙ
# *********************************************************************
# COPY - копирует файлы с хоста (где выполняется docker build) в образ
# Первый аргумент - файл на хост-машине (рядом с Dockerfile)
# Второй аргумент - путь внутри образа
# *********************************************************************

# Копируем главный конфигурационный файл Nginx
# Этот файл должен лежать в той же папке, что и Dockerfile
COPY nginx.conf /etc/nginx/nginx.conf

# Копируем конфиг для нашего Telegram бота
# Это тот самый файл с блоками server, который мы подробно разбирали
COPY biz-helper-telegram-bot /etc/nginx/sites-available/

# *********************************************************************
# АКТИВАЦИЯ КОНФИГА БОТА
# *********************************************************************
# Создаем символическую ссылку из sites-available в sites-enabled
# Это стандартный способ "включить" сайт в Debian/Ubuntu
# ln -s - создает ссылку (как ярлык в Windows)
# После этого Nginx "увидит" наш конфиг
# *********************************************************************
RUN ln -s /etc/nginx/sites-available/biz-helper-telegram-bot /etc/nginx/sites-enabled/

# *********************************************************************
# ПРОВЕРКА КОНФИГУРАЦИИ
# *********************************************************************
# Запускаем встроенную проверку Nginx.
# Если в конфигах есть синтаксическая ошибка - сборка образа остановится.
# Это защищает от создания образа с нерабочей конфигурацией.
# *********************************************************************
RUN nginx -t

# *********************************************************************
# ОТКРЫТИЕ ПОРТОВ
# *********************************************************************
# EXPOSE - документирует, какие порты будет слушать контейнер.
# НЕ открывает порты наружу автоматически, а просто говорит:
# "Этому контейнеру нужны порты 80 и 443".
# Реально открываются через -p или ports в docker-compose.
# *********************************************************************
EXPOSE 80   # HTTP - для перенаправления на HTTPS и проверок Let's Encrypt
EXPOSE 443  # HTTPS - основной порт, где работает бот

# *********************************************************************
# ЗАПУСК NGINX
# *********************************************************************
# CMD - команда, которая выполнится при запуске контейнера.
# "nginx" - запустить nginx
# "-g" - передать глобальную директиву
# "daemon off;" - сказать nginx НЕ уходить в фоновый режим
#
# Почему daemon off? 
# Docker контейнер живет, пока живет его главный процесс.
# Если nginx уйдет в фон (daemon on), Docker подумает, что процесс завершился,
# и убьет контейнер. Поэтому нужно, чтобы nginx оставался на переднем плане.
# *********************************************************************
CMD ["nginx", "-g", "daemon off;"]